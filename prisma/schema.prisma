generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum DeviceStatus {
  ACTIVE
  REVOKED
  PENDING
}

enum QrLoginChallengeStatus {
  PENDING
  SCANNED
  FOLLOWED
  APPROVED
  EXPIRED
  CONSUMED
  CANCELED
}

enum ChannelEnvironment {
  DEV
  STAGING
  PROD
}

model User {
  id                 String             @id @default(cuid())
  email              String             @unique
  emailVerifiedAt    DateTime?
  passwordHash       String?
  name               String?
  displayName        String?            @unique
  displayNameSeq     Int?               @unique
  publicUserId       String?            @unique
  remarkName         String?
  avatarUrl          String?
  firstLoginAt       DateTime?
  lastLoginAt        DateTime?
  wechatOpenId       String?            @unique
  wechatUnionId      String?
  wechatFollowed     Boolean            @default(false)
  wechatFollowedAt   DateTime?
  wechatNickname     String?
  wechatAvatarUrl    String?
  wechatSex          Int?
  wechatLanguage     String?
  wechatCity         String?
  wechatProvince     String?
  wechatCountry      String?
  wechatProfileSyncStatus String?
  wechatProfileSyncError  String?
  wechatProfileSyncedAt   DateTime?
  lastWechatEvent    String?
  lastWechatEventAt  DateTime?
  role               UserRole           @default(USER)
  status             UserStatus         @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  devices        Device[]
  loginCodes     LoginCode[]
  qrChallenges   QrLoginChallenge[]
  authSessions   AuthSession[]
  auditLogs      AuditLog[]

  @@index([wechatOpenId])
  @@index([wechatUnionId])
  @@index([displayName])
  @@index([publicUserId])
}

model Device {
  id            String       @id @default(cuid())
  userId        String?
  clientDeviceId String?
  deviceName    String
  deviceType    String?
  platform      String?
  clientVersion String?
  status        DeviceStatus @default(PENDING)
  lastSeenAt    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  user         User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  loginCodes   LoginCode[]
  qrChallenges QrLoginChallenge[]
  authSessions AuthSession[]

  @@index([userId])
  @@index([clientDeviceId])
}

model LoginCode {
  id        String   @id @default(cuid())
  code      String   @unique
  userId    String?
  deviceId  String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
}

model QrLoginChallenge {
  id                 String                 @id @default(cuid())
  userId             String?
  deviceId           String?
  clientDeviceId     String?
  status             QrLoginChallengeStatus @default(PENDING)
  qrToken            String                 @unique
  qrUrl              String?
  qrTicket           String?
  qrSource           String?
  qrCreateError      String?
  fallbackQrUrl      String?
  wechatOpenId       String?
  wechatEventKey     String?
  lastWechatEvent    String?
  lastWechatEventAt  DateTime?
  scannedAt          DateTime?
  followedAt         DateTime?
  expiresAt          DateTime
  approvedAt         DateTime?
  consumedAt         DateTime?
  canceledAt         DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
  @@index([clientDeviceId])
  @@index([status])
  @@index([wechatOpenId])
}

model AuthSession {
  id                    String   @id @default(cuid())
  userId                String
  deviceId              String?
  accessTokenHash       String   @unique
  refreshTokenHash      String   @unique
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  lastSeenAt            DateTime?
  revokedAt             DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device? @relation(fields: [deviceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([deviceId])
  @@index([revokedAt])
}

model ChannelConfig {
  id                      String             @id @default(cuid())
  channelType             String             @unique
  originalId              String?
  appId                   String?
  appSecretEncrypted      String?
  callbackUrl             String?
  qrLoginBaseUrl          String?
  signingSecretEncrypted  String?
  encodingAesKeyEncrypted String?
  webhookUrl              String?
  verifyToken             String?
  allowedPlatforms        Json?
  deviceBindingMode       String?            @default("OPTIONAL")
  challengeTtlSeconds     Int?               @default(300)
  pollingIntervalMs       Int?               @default(2000)
  enabled                 Boolean            @default(false)
  environment             ChannelEnvironment @default(DEV)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
}

model Announcement {
  id          String   @id @default(cuid())
  category    String
  title       String
  content     String
  summary     String?
  status      String   @default("ACTIVE")
  pinned      Boolean  @default(false)
  sortOrder   Int      @default(0)
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OnboardingConfig {
  key                String   @id
  badge              String
  titleLine1         String
  titleLine2         String
  description        String
  featureTagsJson    Json
  qrTitle            String
  stepsJson          Json
  statusSectionTitle String
  statusTitle        String
  statusDescription  String
  statusCardsJson    Json
  completionTip      String
  primaryButton      String
  secondaryButton    String
  contactText        String
  updatedAt          DateTime @updatedAt
}

model AppCounter {
  key       String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  targetType   String?
  targetId     String?
  metadataJson Json?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([targetType, targetId])
}
